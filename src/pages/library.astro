---
import Base from "@/layouts/Base.astro";
import { siteConfig } from "@/site.config";
---

<Base meta={{ title: "Library", description: "Collection of resources and references" }}>
	<main class="prose prose-lg">
		<h1>Library</h1>
		<p class="text-lg text-accent/80">A curated collection of resources, references, and useful information to help you learn and grow.</p>
		
		<!-- Documentation Section -->
		<section class="mt-8">
			<h2 class="text-xl font-semibold mb-4">Documentation</h2>
			<div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
				<div class="p-6 bg-accent/5 rounded-lg border border-accent/10 hover:bg-accent/10 transition-colors group">
					<div class="flex items-center space-x-3 mb-4">
						<svg class="w-8 h-8 text-accent group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
						</svg>
						<h3 class="text-lg font-semibold">API References</h3>
					</div>
					<p class="text-sm text-accent/70 mb-4">Comprehensive API documentation for popular frameworks and libraries.</p>
					<ul class="text-sm space-y-2">
						<li class="flex items-center space-x-2">
							<span class="w-2 h-2 bg-blue-500 rounded-full"></span>
							<span>React Documentation</span>
						</li>
						<li class="flex items-center space-x-2">
							<span class="w-2 h-2 bg-green-500 rounded-full"></span>
							<span>Vue.js Guide</span>
						</li>
						<li class="flex items-center space-x-2">
							<span class="w-2 h-2 bg-purple-500 rounded-full"></span>
							<span>Astro Docs</span>
						</li>
					</ul>
				</div>
				
				<div class="p-6 bg-accent/5 rounded-lg border border-accent/10 hover:bg-accent/10 transition-colors group">
					<div class="flex items-center space-x-3 mb-4">
						<svg class="w-8 h-8 text-accent group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
						</svg>
						<h3 class="text-lg font-semibold">User Guides</h3>
					</div>
					<p class="text-sm text-accent/70 mb-4">Step-by-step guides and tutorials for various technologies and tools.</p>
					<ul class="text-sm space-y-2">
						<li class="flex items-center space-x-2">
							<span class="w-2 h-2 bg-blue-500 rounded-full"></span>
							<span>Getting Started Guides</span>
						</li>
						<li class="flex items-center space-x-2">
							<span class="w-2 h-2 bg-green-500 rounded-full"></span>
							<span>Best Practices</span>
						</li>
						<li class="flex items-center space-x-2">
							<span class="w-2 h-2 bg-purple-500 rounded-full"></span>
							<span>Troubleshooting</span>
						</li>
					</ul>
				</div>
				
				<div class="p-6 bg-accent/5 rounded-lg border border-accent/10 hover:bg-accent/10 transition-colors group">
					<div class="flex items-center space-x-3 mb-4">
						<svg class="w-8 h-8 text-accent group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
						</svg>
						<h3 class="text-lg font-semibold">Best Practices</h3>
					</div>
					<p class="text-sm text-accent/70 mb-4">Industry standards and recommended practices for development.</p>
					<ul class="text-sm space-y-2">
						<li class="flex items-center space-x-2">
							<span class="w-2 h-2 bg-blue-500 rounded-full"></span>
							<span>Code Standards</span>
						</li>
						<li class="flex items-center space-x-2">
							<span class="w-2 h-2 bg-green-500 rounded-full"></span>
							<span>Security Guidelines</span>
						</li>
						<li class="flex items-center space-x-2">
							<span class="w-2 h-2 bg-purple-500 rounded-full"></span>
							<span>Performance Tips</span>
						</li>
					</ul>
				</div>
			</div>
		</section>

		<!-- Learning Resources Section -->
		<section class="mt-8">
			<h2 class="text-xl font-semibold mb-4">Learning Resources</h2>
			<div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
				<div class="p-6 bg-accent/5 rounded-lg border border-accent/10 hover:bg-accent/10 transition-colors group">
					<div class="flex items-center space-x-3 mb-4">
						<svg class="w-8 h-8 text-accent group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
						</svg>
						<h3 class="text-lg font-semibold">Video Tutorials</h3>
					</div>
					<p class="text-sm text-accent/70 mb-4">Curated video content from top educators and developers.</p>
					<div class="flex flex-wrap gap-2">
						<span class="px-2 py-1 bg-red-500/20 text-red-600 text-xs rounded">YouTube</span>
						<span class="px-2 py-1 bg-blue-500/20 text-blue-600 text-xs rounded">Udemy</span>
						<span class="px-2 py-1 bg-green-500/20 text-green-600 text-xs rounded">Pluralsight</span>
					</div>
				</div>
				
				<div class="p-6 bg-accent/5 rounded-lg border border-accent/10 hover:bg-accent/10 transition-colors group">
					<div class="flex items-center space-x-3 mb-4">
						<svg class="w-8 h-8 text-accent group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
						</svg>
						<h3 class="text-lg font-semibold">Interactive Courses</h3>
					</div>
					<p class="text-sm text-accent/70 mb-4">Hands-on learning experiences with real-world projects.</p>
					<div class="flex flex-wrap gap-2">
						<span class="px-2 py-1 bg-orange-500/20 text-orange-600 text-xs rounded">freeCodeCamp</span>
						<span class="px-2 py-1 bg-blue-500/20 text-blue-600 text-xs rounded">Codecademy</span>
						<span class="px-2 py-1 bg-green-500/20 text-green-600 text-xs rounded">The Odin Project</span>
					</div>
				</div>
				
				<div class="p-6 bg-accent/5 rounded-lg border border-accent/10 hover:bg-accent/10 transition-colors group">
					<div class="flex items-center space-x-3 mb-4">
						<svg class="w-8 h-8 text-accent group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
						</svg>
						<h3 class="text-lg font-semibold">Reference Books</h3>
					</div>
					<p class="text-sm text-accent/70 mb-4">Essential books and e-books for deep learning and reference.</p>
					<div class="flex flex-wrap gap-2">
						<span class="px-2 py-1 bg-blue-500/20 text-blue-600 text-xs rounded">O'Reilly</span>
						<span class="px-2 py-1 bg-green-500/20 text-green-600 text-xs rounded">Manning</span>
						<span class="px-2 py-1 bg-purple-500/20 text-purple-600 text-xs rounded">Pragmatic</span>
					</div>
				</div>
			</div>
		</section>

		<!-- Templates & Snippets Section -->
		<section class="mt-8">
			<h2 class="text-xl font-semibold mb-4">Templates & Snippets</h2>
			<div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
				<div class="p-6 bg-accent/5 rounded-lg border border-accent/10 hover:bg-accent/10 transition-colors group">
					<div class="flex items-center space-x-3 mb-4">
						<svg class="w-8 h-8 text-accent group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z"></path>
						</svg>
						<h3 class="text-lg font-semibold">Project Templates</h3>
					</div>
					<p class="text-sm text-accent/70 mb-4">Ready-to-use project templates for common use cases.</p>
					<ul class="text-sm space-y-2">
						<li class="flex items-center space-x-2">
							<span class="w-2 h-2 bg-blue-500 rounded-full"></span>
							<span>React Starter</span>
						</li>
						<li class="flex items-center space-x-2">
							<span class="w-2 h-2 bg-green-500 rounded-full"></span>
							<span>Vue Template</span>
						</li>
						<li class="flex items-center space-x-2">
							<span class="w-2 h-2 bg-purple-500 rounded-full"></span>
							<span>Astro Theme</span>
						</li>
					</ul>
				</div>
				
				<div class="p-6 bg-accent/5 rounded-lg border border-accent/10 hover:bg-accent/10 transition-colors group">
					<div class="flex items-center space-x-3 mb-4">
						<svg class="w-8 h-8 text-accent group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
						</svg>
						<h3 class="text-lg font-semibold">Code Snippets</h3>
					</div>
					<p class="text-sm text-accent/70 mb-4">Reusable code snippets for common programming tasks.</p>
					<div class="flex flex-wrap gap-2">
						<span class="px-2 py-1 bg-blue-500/20 text-blue-600 text-xs rounded">JavaScript</span>
						<span class="px-2 py-1 bg-green-500/20 text-green-600 text-xs rounded">Python</span>
						<span class="px-2 py-1 bg-purple-500/20 text-purple-600 text-xs rounded">CSS</span>
					</div>
				</div>
				
				<div class="p-6 bg-accent/5 rounded-lg border border-accent/10 hover:bg-accent/10 transition-colors group">
					<div class="flex items-center space-x-3 mb-4">
						<svg class="w-8 h-8 text-accent group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17v.01"></path>
						</svg>
						<h3 class="text-lg font-semibold">Design Resources</h3>
					</div>
					<p class="text-sm text-accent/70 mb-4">UI/UX resources, icons, and design assets.</p>
					<div class="flex flex-wrap gap-2">
						<span class="px-2 py-1 bg-blue-500/20 text-blue-600 text-xs rounded">Icons</span>
						<span class="px-2 py-1 bg-green-500/20 text-green-600 text-xs rounded">Fonts</span>
						<span class="px-2 py-1 bg-purple-500/20 text-purple-600 text-xs rounded">Mockups</span>
					</div>
				</div>
			</div>
		</section>

		<!-- Collections Section -->
		<section class="mt-8">
			<h2 class="text-xl font-semibold mb-4">Collections</h2>
			<div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
				<div class="p-6 bg-accent/5 rounded-lg border border-accent/10 hover:bg-accent/10 transition-colors group">
					<div class="flex items-center space-x-3 mb-4">
						<svg class="w-8 h-8 text-accent group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"></path>
						</svg>
						<h3 class="text-lg font-semibold">Bookmarked Items</h3>
					</div>
					<p class="text-sm text-accent/70 mb-4">Your saved and bookmarked resources for quick access.</p>
					<div class="text-sm text-accent/60">
						<span class="font-medium">12 items</span> saved
					</div>
				</div>
				
				<div class="p-6 bg-accent/5 rounded-lg border border-accent/10 hover:bg-accent/10 transition-colors group">
					<div class="flex items-center space-x-3 mb-4">
						<svg class="w-8 h-8 text-accent group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
						</svg>
						<h3 class="text-lg font-semibold">Favorites</h3>
					</div>
					<p class="text-sm text-accent/70 mb-4">Your most frequently used and favorite resources.</p>
					<div class="text-sm text-accent/60">
						<span class="font-medium">8 items</span> favorited
					</div>
				</div>
				
				<div class="p-6 bg-accent/5 rounded-lg border border-accent/10 hover:bg-accent/10 transition-colors group">
					<div class="flex items-center space-x-3 mb-4">
						<svg class="w-8 h-8 text-accent group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"></path>
						</svg>
						<h3 class="text-lg font-semibold">Archives</h3>
					</div>
					<p class="text-sm text-accent/70 mb-4">Historical resources and older versions of documentation.</p>
					<div class="text-sm text-accent/60">
						<span class="font-medium">24 items</span> archived
					</div>
				</div>
			</div>
		</section>
	</main>
</Base> 