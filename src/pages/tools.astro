---
import Base from "@/layouts/Base.astro";
import { siteConfig } from "@/site.config";
---

<Base meta={{ title: "Tools", description: "Useful tools and utilities" }}>
	<main class="prose prose-lg">
		<h1>Tools</h1>
		<p class="text-lg text-accent/80">A collection of useful tools and utilities to help you with various tasks. Click on any tool to get started.</p>
		
		<!-- Development Tools -->
		<section class="mt-8">
			<h2 class="text-xl font-semibold mb-4">Development Tools</h2>
			<div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
				<div class="p-6 bg-accent/5 rounded-lg border border-accent/10 hover:bg-accent/10 transition-colors group cursor-pointer">
					<div class="flex items-center space-x-3 mb-4">
						<svg class="w-8 h-8 text-accent group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
						</svg>
						<h3 class="text-lg font-semibold">Code Formatter</h3>
					</div>
					<p class="text-sm text-accent/70 mb-4">Format your code with proper indentation and styling for multiple languages.</p>
					<div class="flex space-x-2">
						<span class="px-2 py-1 bg-accent/20 text-accent text-xs rounded">JavaScript</span>
						<span class="px-2 py-1 bg-accent/20 text-accent text-xs rounded">Python</span>
						<span class="px-2 py-1 bg-accent/20 text-accent text-xs rounded">CSS</span>
					</div>
				</div>
				
				<div class="p-6 bg-accent/5 rounded-lg border border-accent/10 hover:bg-accent/10 transition-colors group cursor-pointer">
					<div class="flex items-center space-x-3 mb-4">
						<svg class="w-8 h-8 text-accent group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
						</svg>
						<h3 class="text-lg font-semibold">JSON Validator</h3>
					</div>
					<p class="text-sm text-accent/70 mb-4">Validate and format JSON data with syntax highlighting and error detection.</p>
					<div class="flex space-x-2">
						<span class="px-2 py-1 bg-green-500/20 text-green-600 text-xs rounded">Validate</span>
						<span class="px-2 py-1 bg-blue-500/20 text-blue-600 text-xs rounded">Format</span>
					</div>
				</div>
				
				<div class="p-6 bg-accent/5 rounded-lg border border-accent/10 hover:bg-accent/10 transition-colors group cursor-pointer">
					<div class="flex items-center space-x-3 mb-4">
						<svg class="w-8 h-8 text-accent group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
						</svg>
						<h3 class="text-lg font-semibold">API Tester</h3>
					</div>
					<p class="text-sm text-accent/70 mb-4">Test REST APIs with different HTTP methods, headers, and request bodies.</p>
					<div class="flex space-x-2">
						<span class="px-2 py-1 bg-purple-500/20 text-purple-600 text-xs rounded">GET</span>
						<span class="px-2 py-1 bg-green-500/20 text-green-600 text-xs rounded">POST</span>
						<span class="px-2 py-1 bg-yellow-500/20 text-yellow-600 text-xs rounded">PUT</span>
					</div>
				</div>
			</div>
		</section>

		<!-- Design Tools -->
		<section class="mt-8">
			<h2 class="text-xl font-semibold mb-4">Design Tools</h2>
			<div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
				<div class="p-6 bg-accent/5 rounded-lg border border-accent/10 hover:bg-accent/10 transition-colors group cursor-pointer">
					<div class="flex items-center space-x-3 mb-4">
						<svg class="w-8 h-8 text-accent group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17v.01"></path>
						</svg>
						<h3 class="text-lg font-semibold">Color Palette</h3>
					</div>
					<p class="text-sm text-accent/70 mb-4">Generate beautiful color palettes with complementary and analogous colors.</p>
					<div class="flex space-x-1">
						<div class="w-6 h-6 bg-red-500 rounded"></div>
						<div class="w-6 h-6 bg-blue-500 rounded"></div>
						<div class="w-6 h-6 bg-green-500 rounded"></div>
						<div class="w-6 h-6 bg-yellow-500 rounded"></div>
						<div class="w-6 h-6 bg-purple-500 rounded"></div>
					</div>
				</div>
				
				<div class="p-6 bg-accent/5 rounded-lg border border-accent/10 hover:bg-accent/10 transition-colors group cursor-pointer">
					<div class="flex items-center space-x-3 mb-4">
						<svg class="w-8 h-8 text-accent group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
						</svg>
						<h3 class="text-lg font-semibold">Image Optimizer</h3>
					</div>
					<p class="text-sm text-accent/70 mb-4">Compress and optimize images for web use while maintaining quality.</p>
					<div class="flex space-x-2">
						<span class="px-2 py-1 bg-accent/20 text-accent text-xs rounded">JPG</span>
						<span class="px-2 py-1 bg-accent/20 text-accent text-xs rounded">PNG</span>
						<span class="px-2 py-1 bg-accent/20 text-accent text-xs rounded">WebP</span>
					</div>
			</div>
			
				<div class="p-6 bg-accent/5 rounded-lg border border-accent/10 hover:bg-accent/10 transition-colors group cursor-pointer">
					<div class="flex items-center space-x-3 mb-4">
						<svg class="w-8 h-8 text-accent group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path>
						</svg>
						<h3 class="text-lg font-semibold">QR Generator</h3>
					</div>
					<p class="text-sm text-accent/70 mb-4">Create QR codes for URLs, text, or contact information with custom styling.</p>
					<div class="flex space-x-2">
						<span class="px-2 py-1 bg-accent/20 text-accent text-xs rounded">URL</span>
						<span class="px-2 py-1 bg-accent/20 text-accent text-xs rounded">Text</span>
						<span class="px-2 py-1 bg-accent/20 text-accent text-xs rounded">Contact</span>
					</div>
				</div>
			</div>
		</section>

		<!-- Utility Tools -->
		<section class="mt-8">
			<h2 class="text-xl font-semibold mb-4">Utility Tools</h2>
			<div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
				<div class="p-6 bg-accent/5 rounded-lg border border-accent/10 hover:bg-accent/10 transition-colors group cursor-pointer">
					<div class="flex items-center space-x-3 mb-4">
						<svg class="w-8 h-8 text-accent group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
						</svg>
						<h3 class="text-lg font-semibold">Password Generator</h3>
					</div>
					<p class="text-sm text-accent/70 mb-4">Generate secure passwords with customizable length and character sets.</p>
					<div class="flex space-x-2">
						<span class="px-2 py-1 bg-accent/20 text-accent text-xs rounded">Strong</span>
						<span class="px-2 py-1 bg-accent/20 text-accent text-xs rounded">Custom</span>
					</div>
				</div>
				
				<div class="p-6 bg-accent/5 rounded-lg border border-accent/10 hover:bg-accent/10 transition-colors group cursor-pointer">
					<div class="flex items-center space-x-3 mb-4">
						<svg class="w-8 h-8 text-accent group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
						</svg>
						<h3 class="text-lg font-semibold">Date Calculator</h3>
					</div>
					<p class="text-sm text-accent/70 mb-4">Calculate date differences, add/subtract days, and convert between formats.</p>
					<div class="flex space-x-2">
						<span class="px-2 py-1 bg-accent/20 text-accent text-xs rounded">Difference</span>
						<span class="px-2 py-1 bg-accent/20 text-accent text-xs rounded">Add/Subtract</span>
					</div>
			</div>
			
				<div class="p-6 bg-accent/5 rounded-lg border border-accent/10 hover:bg-accent/10 transition-colors group cursor-pointer">
					<div class="flex items-center space-x-3 mb-4">
						<svg class="w-8 h-8 text-accent group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3"></path>
						</svg>
						<h3 class="text-lg font-semibold">Unit Converter</h3>
					</div>
					<p class="text-sm text-accent/70 mb-4">Convert between different units of measurement, currency, and temperature.</p>
					<div class="flex space-x-2">
						<span class="px-2 py-1 bg-accent/20 text-accent text-xs rounded">Length</span>
						<span class="px-2 py-1 bg-accent/20 text-accent text-xs rounded">Weight</span>
						<span class="px-2 py-1 bg-accent/20 text-accent text-xs rounded">Currency</span>
					</div>
				</div>
			</div>
		</section>

		<!-- Coming Soon Section -->
		<section class="mt-8">
			<h2 class="text-xl font-semibold mb-4">Coming Soon</h2>
			<div class="bg-accent/5 rounded-lg border border-accent/10 p-6">
				<p class="text-sm text-accent/70 mb-4">More tools are being developed. Have a suggestion? Let us know!</p>
				<div class="flex flex-wrap gap-2">
					<span class="px-3 py-1 bg-accent/20 text-accent text-sm rounded-full">Markdown Editor</span>
					<span class="px-3 py-1 bg-accent/20 text-accent text-sm rounded-full">Base64 Encoder</span>
					<span class="px-3 py-1 bg-accent/20 text-accent text-sm rounded-full">URL Shortener</span>
					<span class="px-3 py-1 bg-accent/20 text-accent text-sm rounded-full">Text Diff Tool</span>
			</div>
		</div>
		</section>
	</main>
</Base> 