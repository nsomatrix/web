---
import ThemeToggle from "@/components/ThemeToggle.astro";
import { menuLinks } from "@/site.config";
import {siteConfig} from "../../site.config";
---

<header class="sticky top-0 z-50 w-full bg-global-bg/70 backdrop-blur-md border-b border-accent/10 shadow-sm" id="main-header">
	<div class="w-full px-4 sm:px-8 py-4">
		<div class="flex items-center justify-between">
			<!-- Logo Section -->
			<div class="flex items-center">
				<a
					aria-current={Astro.url.pathname === "/" ? "page" : false}
					class="flex items-center grayscale hover:filter-none transition-all duration-200"
					href="/"
				>
					<svg
						aria-hidden="true"
						class="h-8 w-6 mr-3"
						fill="none"
						focusable="false"
						viewBox="0 0 272 480"
						xmlns="http://www.w3.org/2000/svg"
					>
						<title>Logo</title>
						<path
							d="M181.334 93.333v-40L226.667 80v40l-45.333-26.667ZM136.001 53.333 90.667 26.667v426.666L136.001 480V53.333Z"
							fill="#B04304"></path>
						<path
							d="m136.001 119.944 45.333-26.667 45.333 26.667-45.333 26.667-45.333-26.667ZM90.667 26.667 136.001 0l45.333 26.667-45.333 26.666-45.334-26.666ZM181.334 53.277l45.333-26.666L272 53.277l-45.333 26.667-45.333-26.667ZM0 213.277l45.333-26.667 45.334 26.667-45.334 26.667L0 213.277ZM136 239.944l-45.333-26.667v53.333L136 239.944Z"
							fill="#FF5D01"></path>
						<path
							d="m136 53.333 45.333-26.666v120L226.667 120V80L272 53.333V160l-90.667 53.333v240L136 480V306.667L45.334 360V240l45.333-26.667v53.334L136 240V53.333Z"
							fill="#53C68C"></path>
						<path d="M45.334 240 0 213.334v120L45.334 360V240Z" fill="#B04304"></path>
					</svg>
					<span class="text-xl font-bold">{siteConfig.title}</span>
				</a>
			</div>

			<!-- Navigation Menu - Hidden on mobile -->
			<nav
				aria-label="Main menu"
				class="hidden sm:flex items-center space-x-8"
				id="navigation-menu"
			>
				{
					menuLinks.map((link) => (
						<a
							aria-current={Astro.url.pathname === link.path ? "page" : false}
							class="nav-link relative text-accent transition-all duration-300 group"
							data-astro-prefetch
							href={link.path}
						>
							{link.title}
							<div class="nav-link-lines">
								<div class="nav-line nav-line-top"></div>
								<div class="nav-line nav-line-bottom"></div>
							</div>
						</a>
					))
				}
			</nav>

			<!-- Right Side Actions -->
			<div class="flex items-center space-x-4">
				<!-- Accounts Icon -->
				<a
					href="/accounts"
					class="flex items-center justify-center w-8 h-8 rounded-md hover:bg-accent/10 transition-colors duration-200"
					aria-label="Accounts"
				>
					<svg
						aria-hidden="true"
						class="w-5 h-5"
						fill="none"
						stroke="currentColor"
						stroke-width="1.5"
						viewBox="0 0 24 24"
						xmlns="http://www.w3.org/2000/svg"
					>
						<path d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" stroke-linecap="round" stroke-linejoin="round"></path>
					</svg>
				</a>
				<ThemeToggle />
				
				<!-- Mobile Menu Button -->
				<button
					aria-expanded="false"
					aria-haspopup="menu"
					class="sm:hidden flex items-center justify-center w-8 h-8 rounded-md hover:bg-accent/10 transition-colors duration-200"
					id="toggle-navigation-menu"
					type="button"
				>
					<span class="sr-only">Open main menu</span>
					<svg
						aria-hidden="true"
						class="w-5 h-5 transition-all duration-200"
						fill="none"
						stroke="currentColor"
						stroke-width="1.5"
						viewBox="0 0 24 24"
						xmlns="http://www.w3.org/2000/svg"
					>
						<path d="M3.75 9h16.5m-16.5 6.75h16.5" stroke-linecap="round" stroke-linejoin="round"></path>
					</svg>
				</button>
			</div>
		</div>

		<!-- Mobile Navigation Menu -->
		<nav
			aria-label="Mobile menu"
			class="sm:hidden mt-4 py-4 border-t border-accent/10 bg-global-bg/95 backdrop-blur-sm rounded-lg hidden"
			id="mobile-navigation-menu"
		>
			<div class="flex flex-col space-y-2">
				{
					menuLinks.map((link) => (
						<a
							aria-current={Astro.url.pathname === link.path ? "page" : false}
							class="nav-link-mobile relative px-4 py-2 text-accent hover:bg-accent/5 rounded-md transition-all duration-300 group"
							data-astro-prefetch
							href={link.path}
						>
							{link.title}
							<div class="nav-link-lines-mobile">
								<div class="nav-line nav-line-top"></div>
								<div class="nav-line nav-line-bottom"></div>
							</div>
						</a>
					))
				}
			</div>
		</nav>
	</div>
</header>

<script>
	// Simple, clean mobile menu toggle
	const mobileButton = document.getElementById('toggle-navigation-menu');
	const mobileMenu = document.getElementById('mobile-navigation-menu');
	
	if (mobileButton && mobileMenu) {
		mobileButton.addEventListener('click', () => {
			const isExpanded = mobileButton.getAttribute('aria-expanded') === 'true';
			
			mobileButton.setAttribute('aria-expanded', (!isExpanded).toString());
			mobileMenu.classList.toggle('hidden');
			
			// Update button icon
			const svg = mobileButton.querySelector('svg');
			if (svg) {
				if (isExpanded) {
					svg.innerHTML = '<path d="M3.75 9h16.5m-16.5 6.75h16.5" stroke-linecap="round" stroke-linejoin="round"></path>';
				} else {
					svg.innerHTML = '<path d="M6 18L18 6M6 6l12 12" stroke-linecap="round" stroke-linejoin="round"></path>';
				}
			}
		});
	}
</script>
